{
  "require": {
    "altorouter/altorouter": "^2.0",
    "smarty/smarty": "^4.0",
    "vlucas/phpdotenv": "^5.6",
    "ext-pdo": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.11",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "stan": "phpstan analyse",
    "cs": "phpcs",
    "cs-fix": "phpcbf"
  }
}
